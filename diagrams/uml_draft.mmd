classDiagram
    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet) None
        +get_pets() list~Pet~
        +get_all_tasks() list~Pet,Task~
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task) None
        +edit_task(description, changes) bool
        +get_tasks() list~Task~
    }

    class Task {
        +str description
        +datetime due
        +int duration
        +str priority
        +str frequency
        +bool completed
        +mark_complete() None
        +priority_rank() int
    }

    class Scheduler {
        +Owner owner
        +int available_time
        +collect_tasks() list~Pet,Task~
        +sort_tasks() list~Pet,Task~
        +generate_plan() list~Pet,Task~
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler --> Owner : schedules for
